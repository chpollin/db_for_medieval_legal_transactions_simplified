            <origDate instant="false">ze Wienne an sant Michels tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00100_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00100_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_100"><rs type="fn" role="issuer"><rs type="person" ref="pe__konrad_chrannest_QGW_II_I_99">Chunrat der Chrannest</rs> und <rs type="person" ref="pe__elisabeth_QGW_II_I_100">Elsbet, sein <roleName type="kin" corresp="pe__konrad_chrannest_QGW_II_I_99">hausvrowe</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring> ein Haus, das ihnen um versessenes Burgrecht
                  gerichtlich zugesprochen ist, und das da leit bei der padstuben, die da haisset
                  dacz den Ro/eren, baideu hinden und vorn und swas darzu geho/eret, als iz her
                  Jacob der Satler und her Dietreich der Helt von alter inne gehabt habent, und leit
                  zenaehst Hainreichen dem Tirnacher , <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> der <rs type="person" ref="pe__herbert_auf_der_saeule_QGW_II_I_184"><roleName type="title">Grundherren</roleName>, <roleName type="title">hern</roleName> Herbortes
                        auf der Seul</rs> und <rs type="person" ref="pe__wilhelm_in_dem_strohof_QGW_II_I_180"><roleName type="title"><add>Grundherren</add></roleName>
                        <roleName type="title">hern</roleName> Wilhalms in dem Strohof</rs></rs>, um
                  12 lb dn. Geldes Burgrechts dem <rs type="fn" role="recipient"><rs type="person" ref="pe__gerhard_bruenner_QGW_II_I_133"><roleName type="title">Meister</roleName> Gerhart, dem Brünner</rs></rs>. Die Ablösungssumme
                  für je 4 lb dn. Geldes Burgrechts wird mit 18 Mark Silber, die Mark zu 72 grosser
                  pehemischer pheninge, festgestellt. Von dem vorderen Theile sind dem Herrn Herbort
                  auf der Säule jährlich an S. Michaels Tag 12 dn., von dem hinteren Theile
                  ebenfalls 12 dn. dem Herrn Wilhalm in dem Strohof zu Grundrecht zu bezahlen.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_100"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="pe__konrad_chrannest_QGW_II_I_99">1. des
                        Ausstellers</rs>, <rs type="person" ref="pe__herbert_auf_der_saeule_QGW_II_I_184">2.
                     <add>Grundherren</add></rs>, <rs type="person" ref="pe__wilhelm_in_dem_strohof_QGW_II_I_180">3. der Grundherren</rs> und
                        <rs type="person" ref="pe__otto_wilfleinsdorfer_FRA_II_1319_VI_24">4.
                           <roleName type="title">hern</roleName> Otten des
                     Wu/elfleinstorfer</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>